{
  "format_version": "1.21.60",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:rain_splash_particle",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/rain_splah_drop"
      }
    },

    "events": {
      "on_create": {
        "sequence": [
          {
            "particle_effect": {
              "effect": "immersive_rain:rain_puddle",
              "type": "particle"
            }
          }
        ]
      }
    },

    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 300
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1
      },
      "minecraft:emitter_shape_point": {},

      "minecraft:particle_initial_speed": 0,

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(0.18, 0.22)"
      },

      "minecraft:particle_lifetime_events": {
        "creation_event": "on_create"
      },

      "minecraft:particle_appearance_billboard": {
        "size": [ "math.random(0.1, 0.13)", "math.random(0.1, 0.13)" ],
        "facing_camera_mode": "emitter_transform_xz",
        "uv": {
          "texture_width": 64,
          "texture_height": 16,
          "flipbook": {
            "base_UV": [ 0, 0 ],
            "size_UV": [ 16, 16 ],
            "step_UV": [ 16, 0 ],
            "max_frame": 4,
            "stretch_to_lifetime": true
          }
        }
      },

      "minecraft:particle_appearance_lighting": {},

      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": "#80C8ECFF",
            "1.0": "#00C8ECFF"
          }
        }
      }
    }
  }
}
