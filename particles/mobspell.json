{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:mobspell_emitter",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/glowing"
      }
    },
    "components": {

      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },

      "minecraft:emitter_lifetime_once": {},

      "minecraft:emitter_shape_custom": {
        "offset": [
          "variable.px_size = Math.random(0.06, 0.20); variable.is_big = Math.Random(0.0,1.0) > 0.80; variable.color_brightness = 0.8 + Math.random(0.0, 0.2); return Math.random(-0.4, 0.4);",
          "Math.random(0.0, 1.8)",
          "Math.random(-0.4, 0.4)"
        ],
        "direction": [
          "Math.random(-0.3, 0.3)",
          "Math.random(0.05, 0.5)",
          "Math.random(-0.3, 0.3)"
        ]
      },

      "minecraft:particle_initial_speed": "Math.random(0.3, 1.1)",

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.random(1.0, 2.2)"
      },

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "(variable.particle_random_1 * 2.0 - 1.0) * 0.35",
          "0.18 - (variable.particle_age * 0.25)",
          "(variable.particle_random_2 * 2.0 - 1.0) * 0.35"
        ],
        "linear_drag_coefficient": 1.8
      },

      "minecraft:particle_motion_collision": {
        "enabled": 1,
        "expire_on_contact": true,
        "collision_drag": 1.0,
        "coefficient_of_restitution": 0.0,
        "collision_radius": 0.01
      },

      "minecraft:particle_appearance_billboard": {
        "size": [
          "(variable.is_big > 0 ? variable.px_size * 2.4 : variable.px_size)",
          "(variable.is_big > 0 ? variable.px_size * 2.4 : variable.px_size)"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [ 0, 0 ],
          "uv_size": [ 16, 16 ]
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": [
          "variable.color.r * variable.color_brightness",
          "variable.color.g * variable.color_brightness",
          "variable.color.b * variable.color_brightness",
          "variable.color.a * Math.pow(Math.max(0.0, 1.0 - (variable.particle_age / variable.particle_lifetime)), 0.6)"
        ]
      }

    }
  }
}
