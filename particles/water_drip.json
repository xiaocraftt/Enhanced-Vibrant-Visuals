{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:water_drip_particle",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/rain_drip"
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 99999
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [0.0, 0.0, 0.0]
      },
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "1.8 + variable.particle_random_1 * 1.5"
      },
      "minecraft:particle_initial_speed": 0.0,
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          0.0,
          "variable.particle_age < 0.6 ? -0.1 : (-3.5 - variable.particle_random_1 * 2.5)",
          0.0
        ],
        "linear_drag_coefficient": "variable.particle_age < 0.6 ? 8.0 : 0.5"
      },
      "minecraft:particle_motion_collision": {
        "collision_radius": 0.01,
        "collision_drag": 10.0,
        "expire_on_contact": true
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "variable.particle_age < 0.6 ? math.lerp(0.03, 0.055, variable.particle_age / 0.6) : math.lerp(0.04, 0.03, math.min(1.0, (variable.particle_age - 0.6) / 1.0))",
          "variable.particle_age < 0.6 ? math.lerp(0.03, 0.06, variable.particle_age / 0.6) : math.lerp(0.06, 0.12, math.min(1.0, (variable.particle_age - 0.6) / 0.5))"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 32,
          "texture_height": 8,
          "uv": [
            "math.floor(math.min(3, (variable.particle_age / variable.particle_lifetime) * 4)) * 8",
            0
          ],
          "uv_size": [8, 8]
        }
      },
      "minecraft:particle_initial_spin": {
        "rotation": 0
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "variable.particle_age / variable.particle_lifetime",
          "gradient": {
            "0.0":  [0.7, 0.82, 1.0, 0.0],
            "0.1":  [0.7, 0.82, 1.0, 0.75],
            "0.35": [0.7, 0.82, 1.0, 0.9],
            "0.85": [0.7, 0.82, 1.0, 0.8],
            "1.0":  [0.7, 0.82, 1.0, 0.0]
          }
        }
      },
      "minecraft:particle_appearance_lighting": {}
    }
  }
}
