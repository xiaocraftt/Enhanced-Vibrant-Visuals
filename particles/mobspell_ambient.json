{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:mobspell_ambient",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/glowing"
      }
    },
    "components": {

      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },

      "minecraft:emitter_lifetime_once": {},

      "minecraft:emitter_shape_custom": {
        "offset": [
          "variable.px_size = Math.random(0.05, 0.16); variable.color_brightness = 0.5 + Math.random(0.0, 0.3); return Math.random(-0.5, 0.5);",
          "Math.random(0.0, 2.0)",
          "Math.random(-0.5, 0.5)"
        ],
        "direction": [
          "Math.random(-0.2, 0.2)",
          "Math.random(0.1, 0.6)",
          "Math.random(-0.2, 0.2)"
        ]
      },

      "minecraft:particle_initial_speed": "Math.random(0.1, 0.7)",

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.random(1.5, 3.0)"
      },

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "(variable.particle_random_1 * 2.0 - 1.0) * 0.15",
          "0.08 - (variable.particle_age * 0.12)",
          "(variable.particle_random_2 * 2.0 - 1.0) * 0.15"
        ],
        "linear_drag_coefficient": 2.5
      },

      "minecraft:particle_motion_collision": {
        "enabled": 1,
        "collision_drag": 1.0,
        "coefficient_of_restitution": 0.0,
        "collision_radius": 0.5
      },

      "minecraft:particle_appearance_billboard": {
        "size": [
          "variable.px_size",
          "variable.px_size"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [ 0, 0 ],
          "uv_size": [ 16, 16 ]
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": [
          "variable.color.r * variable.color_brightness",
          "variable.color.g * variable.color_brightness",
          "variable.color.b * variable.color_brightness",
          "0.35 * Math.pow(Math.max(0.0, 1.0 - (variable.particle_age / variable.particle_lifetime)), 0.45)"
        ]
      }

    }
  }
}
