{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:villager_happy",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/happy"
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 25
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "direction": [
          "math.random(-0.3, 0.3)",
          "math.random(0.3, 1.0)",
          "math.random(-0.3, 0.3)"
        ]
      },
      "minecraft:particle_initial_speed": "math.random(0.4, 1.2)",
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(1.2, 2.8)"
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "(v.particle_random_1 * 2.0 - 1.0) * 0.3",
          "0.25 + v.particle_random_2 * 0.2",
          "(v.particle_random_3 * 2.0 - 1.0) * 0.3"
        ],
        "linear_drag_coefficient": 1.5
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "math.lerp(0.05, 0.20 + v.particle_random_3 * 0.06, math.clamp(v.particle_age / 0.15, 0, 1)) * math.pow(1.0 - math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 0.6)",
          "math.lerp(0.05, 0.20 + v.particle_random_3 * 0.06, math.clamp(v.particle_age / 0.15, 0, 1)) * math.pow(1.0 - math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 0.6)"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [ 0, 0 ],
          "uv_size": [ 16, 16 ]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          "0.4 + v.particle_random_1 * 0.3",
          "0.9 + v.particle_random_2 * 0.1",
          "0.1 + v.particle_random_3 * 0.15",
          "math.lerp(1.0, 0.0, math.pow(math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 1.5)) * math.clamp(v.particle_age / 0.08, 0, 1)"
        ]
      }
    }
  }
}
