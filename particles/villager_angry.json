{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:villager_angry",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/angry"
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 25
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "direction": [
          "math.random(-0.6, 0.6)",
          "math.random(0.4, 1.0)",
          "math.random(-0.6, 0.6)"
        ]
      },
      "minecraft:particle_initial_speed": "math.random(1.8, 3.5)",
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "math.random(0.3, 1.0)"
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "(v.particle_random_1 * 2.0 - 1.0) * 1.2",
          "-4.0",
          "(v.particle_random_2 * 2.0 - 1.0) * 1.2"
        ],
        "linear_drag_coefficient": 4.0
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "math.lerp(0.18 + v.particle_random_3 * 0.06, 0.04, math.pow(math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 1.2))",
          "math.lerp(0.18 + v.particle_random_3 * 0.06, 0.04, math.pow(math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 1.2))"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [ 0, 0 ],
          "uv_size": [ 16, 16 ]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": [
          1.0,
          "0.2 + v.particle_random_1 * 0.2",
          0.0,
          "math.lerp(1.0, 0.0, math.pow(math.clamp(v.particle_age / v.particle_lifetime, 0, 1), 1.8)) * math.clamp(v.particle_age / 0.05, 0, 1)"
        ]
      }
    }
  }
}
