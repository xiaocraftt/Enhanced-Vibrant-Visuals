{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "minecraft:mobspell_lingering",
      "basic_render_parameters": {
        "material": "particles_add",
        "texture": "textures/particle/glowing"
      }
    },
    "components": {

      "minecraft:emitter_rate_instant": {
        "num_particles": "Math.pi * variable.cloud_radius * variable.cloud_radius * variable.particle_multiplier"
      },

      "minecraft:emitter_lifetime_once": {
        "active_time": "variable.cloud_lifetime"
      },

      "minecraft:emitter_shape_disc": {
        "radius": "variable.cloud_radius",
        "direction": [ 0.0, 1.0, 0.0 ]
      },

      "minecraft:particle_initial_speed": "Math.random(0.2, 0.9)",

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.random(1.0, 2.0)"
      },

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "(variable.particle_random_1 * 2.0 - 1.0) * 0.2",
          "0.5 - (variable.particle_age * 0.3)",
          "(variable.particle_random_2 * 2.0 - 1.0) * 0.2"
        ],
        "linear_drag_coefficient": 2.2
      },

      "minecraft:particle_motion_collision": {
        "enabled": 1,
        "expire_on_contact": true,
        "collision_drag": 1.0,
        "coefficient_of_restitution": 0.0,
        "collision_radius": 0.01
      },

      "minecraft:particle_appearance_billboard": {
        "size": [
          "Math.random(0.06, 0.22)",
          "Math.random(0.06, 0.22)"
        ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [ 0, 0 ],
          "uv_size": [ 16, 16 ]
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": [
          "variable.color.r * (0.75 + Math.random(0.0, 0.25))",
          "variable.color.g * (0.75 + Math.random(0.0, 0.25))",
          "variable.color.b * (0.75 + Math.random(0.0, 0.25))",
          "variable.color.a * Math.pow(Math.max(0.0, 1.0 - (variable.particle_age / variable.particle_lifetime)), 0.5)"
        ]
      }

    }
  }
}
