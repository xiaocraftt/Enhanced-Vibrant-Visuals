{
  "format_version": "1.21.60",
  "particle_effect": {
    "description": {
      "identifier": "immersive_rain:wind_rain_drop",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/particle/particles"
      }
    },

    "components": {

      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },

      "minecraft:emitter_rate_manual": {
        "max_particles": 600
      },

      "minecraft:emitter_shape_sphere": {
        "radius": 14,
        "direction": "outward",
        "surface_only": false
      },

      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "1.2 + variable.particle_random_1 * 0.8"
      },

      "minecraft:particle_initial_speed": [
        "variable.particle_random_2 * 3.5 - 0.5",
        "-10.0 - variable.particle_random_1 * 4.0",
        "variable.particle_random_3 * 0.8 - 0.4"
      ],

      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [
          "2.5 + variable.particle_random_4 * 1.5",
          "-4.0",
          "0.0"
        ],
        "linear_drag_coefficient": 0.02
      },

      "minecraft:particle_motion_collision": {
        "collision_radius": 0.02,
        "collision_drag": 10.0,
        "coefficient_of_restitution": 0.0,
        "enabled": "1 - variable.particle_age / variable.particle_lifetime < 0.15"
      },

      "minecraft:particle_appearance_billboard": {
        "facing_camera_mode": "lookat_xyz",
        "size": [
          "0.025 + variable.particle_random_1 * 0.015",
          "0.18 + variable.particle_random_1 * 0.12"
        ],
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [0, 0],
          "uv_size": [8, 8]
        }
      },

      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "variable.particle_age / variable.particle_lifetime",
          "gradient": {
            "0.0":  [0.75, 0.85, 1.0, 0.0],
            "0.1":  [0.75, 0.85, 1.0, 0.7],
            "0.8":  [0.75, 0.85, 1.0, 0.5],
            "1.0":  [0.75, 0.85, 1.0, 0.0]
          }
        }
      },

      "minecraft:particle_appearance_lighting": {}
    }
  }
}
